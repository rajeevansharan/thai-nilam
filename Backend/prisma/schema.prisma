generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int        @id @default(autoincrement())
  email     String     @unique
  password  String
  name      String
  role      String     @default("USER")
  isPremium Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  purchases Purchase[]
  favorites Favorite[]
}

model Issue {
  id            Int      @id @default(autoincrement())
  title         String?
  description   String
  month         String   // e.g., 1-12 or 'January'
  year          String
  pdfUrl        String
  imageUrl      String   // (coverImage equivalent)
  price         Float    @default(500.0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  contentImages ContentImage[]
  purchases     Purchase[]
  favorites     Favorite[]
}

model ContentImage {
  id      Int    @id @default(autoincrement())
  url     String
  issueId Int
  issue   Issue  @relation(fields: [issueId], references: [id], onDelete: Cascade)
}

enum PurchaseStatus {
  paid
  failed
  pending
}

model Purchase {
  id              Int            @id @default(autoincrement())
  userId          Int
  magazineIssueId Int
  paidAt          DateTime?      
  amount          Float
  status          PurchaseStatus @default(pending)
  
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  issue           Issue          @relation(fields: [magazineIssueId], references: [id], onDelete: Cascade)

  @@unique([userId, magazineIssueId])
  @@index([userId])
  @@index([magazineIssueId])
}

model Favorite {
  id              Int      @id @default(autoincrement())
  userId          Int
  magazineIssueId Int
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  issue           Issue    @relation(fields: [magazineIssueId], references: [id], onDelete: Cascade)

  @@unique([userId, magazineIssueId])
  @@index([userId])
  @@index([magazineIssueId])
}
